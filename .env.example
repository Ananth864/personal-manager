# Clerk
# Get these from https://dashboard.clerk.com → API keys
VITE_CLERK_PUBLISHABLE_KEY=
# Server-only (no VITE_ prefix). Required for clerkMiddleware / auth().
CLERK_SECRET_KEY=

# Supabase (optional in the skeleton ticket; required once Inventory lands)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OpenAI — server-only. The cooking agent (T08) reads these.
OPENAI_API_KEY=
# Model is a config swap (ADR-0007); defaults to gpt-5.6-luna if unset.
OPENAI_MODEL=
